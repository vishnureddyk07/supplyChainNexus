# Core application
APP_NAME=supplyChainNexus
ENVIRONMENT=local
LOG_LEVEL=INFO

# API and frontend
RISK_API_PORT=8000
INGESTION_SERVICE_PORT=8001
GRAPH_SERVICE_PORT=8002
GENAI_SERVICE_PORT=8003
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_SUPPLIER_EVENTS=supplychain.supplier.events
KAFKA_TOPIC_SHIPMENT_EVENTS=supplychain.shipment.events
KAFKA_TOPIC_RISK_EVENTS=supplychain.risk.events

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supplychain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/supplychain

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_HTTP_URI=http://localhost:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=

# Mock services
SUPPLIER_ERP_MOCK_PORT=8004
IOT_SENSOR_MOCK_PORT=8005
